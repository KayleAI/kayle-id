{
  "name": "@kayle-id/database",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "devDependencies": {
    "@types/bun": "latest",
    "@types/pg": "8.15.6",
    "drizzle-kit": "0.31.7"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@kayle-id/config": "*",
    "@upstash/redis": "1.35.6",
    "drizzle-orm": "0.44.7",
    "pg": "8.16.3"
  },
  "scripts": {
    "auth:format": "bunx ultracite fix ./src/schema/auth.ts",
    "auth:generate": "bunx @better-auth/cli@latest generate --config ../auth/src/server.ts --output ./src/schema/auth.ts --yes && bun run auth:format",
    "db:generate": "drizzle-kit generate --config ../../drizzle.config.ts",
    "db:migrate": "drizzle-kit migrate --config ../../drizzle.config.ts",
    "db:seed": "bun ./src/seed.ts",
    "db:studio": "drizzle-kit studio --config ../../drizzle.config.ts"
  },
  "exports": {
    "./*": "./src/*.ts"
  }
}
