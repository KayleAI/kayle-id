{
  "name": "kayle-id",
  "description": "Privacy-first identity verification.",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "turbo run dev --filter=kayle-id-api --filter=kayle-id-web",
    "dev:ios": "turbo run dev --filter=kayle-id-ios",
    "dev:android": "turbo run dev --filter=kayle-id-android",
    "cf-typegen": "turbo run cf-typegen",
    "db:setup": "cd packages/database && bun run db:migrate && bun run db:seed",
    "db:start": "docker compose up -d",
    "db:stop": "docker compose down",
    "db:logs": "docker compose logs -f",
    "db:clean": "docker compose down -v && docker volume rm pgdata",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.7",
    "@types/pg": "8.15.6",
    "dotenv": "17.2.3",
    "drizzle-kit": "0.31.7",
    "husky": "9.1.7",
    "turbo": "2.6.1",
    "ultracite": "6.3.5",
    "wrangler": "4.51.0"
  },
  "packageManager": "bun@1.3.3",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "drizzle-orm": "0.44.7",
    "pg": "8.16.3"
  }
}
